{
  "family": "contrato-ia-backend-staging",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::role/contrato-ia-backend-task-role",
  "containerDefinitions": [
    {
      "name": "contrato-ia-backend",
      "image": "PLACEHOLDER",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8080,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "SPRING_PROFILES_ACTIVE", "value": "staging" },
        { "name": "JAVA_OPTS", "value": "-XX:+UseContainerSupport -XX:MaxRAMPercentage=75.0" }
      ],
      "secrets": [
        { "name": "DB_URL", "valueFrom": "arn:aws:secretsmanager:sa-east-1::secret:contrato-ia/staging/db-url" },
        { "name": "DB_USERNAME", "valueFrom": "arn:aws:secretsmanager:sa-east-1::secret:contrato-ia/staging/db-username" },
        { "name": "DB_PASSWORD", "valueFrom": "arn:aws:secretsmanager:sa-east-1::secret:contrato-ia/staging/db-password" },
        { "name": "KEYCLOAK_ISSUER_URI", "valueFrom": "arn:aws:secretsmanager:sa-east-1::secret:contrato-ia/staging/keycloak-issuer" },
        { "name": "CLAUDE_API_KEY", "valueFrom": "arn:aws:secretsmanager:sa-east-1::secret:contrato-ia/staging/claude-api-key" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/contrato-ia-backend-staging",
          "awslogs-region": "sa-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "curl -f http://localhost:8080/api/actuator/health || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 60
      }
    }
  ]
}
